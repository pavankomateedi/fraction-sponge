{
  "name": "fraction-sponge",
  "version": "1.0.0",
  "description": "Fraction Sponge — a Synthesis-style math tutor that teaches 1/2 = 2/4 through split-and-smash exploration.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "eval": "node evals/run.js",
    "eval:judge": "node -e \"process.env.JUDGE='1';require('./evals/run.js')\"",
    "eval:verbose": "node -e \"process.env.EVAL_SHOW_RESPONSES='1';process.env.EVAL_VERBOSE='1';require('./evals/run.js')\"",
    "eval:live": "node -e \"process.env.EVAL_BASE_URL='https://web-production-44b1.up.railway.app';require('./evals/run.js')\"",
    "eval:live:judge": "node -e \"process.env.EVAL_BASE_URL='https://web-production-44b1.up.railway.app';process.env.JUDGE='1';require('./evals/run.js')\"",
    "preflight": "node scripts/preflight.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "keywords": ["education", "math", "fractions", "tutor", "synthesis"],
  "author": "Pavan",
  "license": "ISC"
}
